{
  "ConnectionStrings": {
    "MetricsDb": "Server=.;Database=BloomMetricsDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "BloomFilter": {
    "BitSize": 100000,
    "HashFunctionCount": 3,
    "CacheKey": "bloom:primary"
  },
  "BloomMetricsPersist": {
    "Enabled": true,
    "IntervalSeconds": 60,
    "InstanceName": "BloomApi-Node1",
    "ForcePersistIntervalMinutes": 30
  },
  "AllowedHosts": "*"
}
